<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BluetoothWinUI3.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BluetoothWinUI3"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="BluetoothWinUI3">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="rootPanel">
        <!-- WEIRD: See https://learn.microsoft.com/en-us/windows/windows-app-sdk/api/winrt/microsoft.ui.xaml.controls.contentdialog?view=windows-app-sdk-1.8 for why the rootPanel needs to be named that way -->
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        
        <!-- Title and menu -->
        <MenuBar Grid.Row="0">
            <MenuBarItem Title="File" AccessKey="F">
                <ToggleMenuFlyoutItem Text="Keep Screen On" Click="OnFileKeepScreenOn" AccessKey="k" />
                <MenuFlyoutItem Text="Exit" Click="OnFileExit" AccessKey="x" />
            </MenuBarItem>
            <MenuBarItem Title="Bluetooth Device" AccessKey="B">
                <MenuFlyoutItem Text="Rename" Click="OnBTRename" AccessKey="R" />
            </MenuBarItem>
            <MenuBarItem Title="Debug" x:Name="uiMenuDebug" AccessKey="D">
                <MenuFlyoutItem Text="Load Devices" Click="OnDebugLoadDevices" AccessKey="L" />
                <MenuFlyoutItem Text="Save Devices" Click="OnDebugSaveDevices" AccessKey="S" />
            </MenuBarItem>
            <MenuBarItem Title="Help" AccessKey="H">
                <MenuFlyoutItem Text="About" Click="OnHelpAbout" AccessKey="a" />
            </MenuBarItem>
        </MenuBar>

        <!-- All of the known devices -->
        <GridView Grid.Row="1" x:Name="uiKnownDevices" SelectionMode="Single">
        </GridView>

        <!-- Status row -->
        <StackPanel Grid.Row="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Start" Click="OnAdvertisementStart" />
                    <Button Content="Stop" Click="OnAdvertisementStop" />
                    <Button Content="Copy All" Click="OnAdvertisementCopy" />
                    <Button Content="Copy Unique" Click="OnAdvertisementCopyUnique" />
                    <Button Content="Copy Addresses" Click="OnAdvertisementCopyUniqueAddresses" />
                    <TextBlock>N=</TextBlock>
                    <TextBlock x:Name="uiAdvertCount" />
                    <TextBlock>  | RAW=</TextBlock>
                    <TextBlock x:Name="uiAdvertRaw" />
                </StackPanel>
            </Grid>
            
        </StackPanel>
        <ContentDialog x:Name="uiDialogRenameDevice" Title="Rename Device"
                       PrimaryButtonText="Ok" IsPrimaryButtonEnabled="True">
            <TextBox x:Name="uiDialogRenameDeviceName" />
        </ContentDialog>

    </Grid>
</Window>
