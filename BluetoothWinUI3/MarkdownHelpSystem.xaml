<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="BluetoothWinUI3.MarkdownHelpSystem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BluetoothWinUI3"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" MinWidth="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel x:Name="uiNavigation" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                <Button Content="◂" Click="OnBackParent" />
            </StackPanel>
            <TextBlock Grid.Column="1" Style="{StaticResource sTitle}">Guidance and Help</TextBlock>
        </Grid>
        <ScrollView  Grid.Row="1">
            <toolkit:MarkdownTextBlock x:Name="uiHelp" Text="# Let's get you connected" 
                                                   OnLinkClicked="OnHelpLinkClicked" 
                                                   />
            <!--
                        UriPrefix="ms-appx:///Assets/HelpFiles/"
                                           LinkClicked="OnHelpLinkClicked"
                                           ImageMaxHeight="400" />
                        
                        -->
        </ScrollView>
    </Grid>

</UserControl>
