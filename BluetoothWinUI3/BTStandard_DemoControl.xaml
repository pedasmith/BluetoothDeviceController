<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="BluetoothWinUI3.BTStandard_DemoControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BluetoothWinUI3"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:oxyplot="using:OxyPlot"
    xmlns:tv="using:WinUI.TableView"
    mc:Ignorable="d"
    >

    <Border Style="{StaticResource sDeviceBorder}" x:Name="rootPanel">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <TextBlock x:Name="uiKnownDeviceName" Grid.Row="0" Text="Demonstration Display" Style="{StaticResource sDeviceTitle}"/>
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <GridView Grid.Row="0" Style="{StaticResource sDeviceDataList}" x:Name="uiDeviceDataList">

                    <StackPanel Style="{StaticResource sDeviceDataPanel}">
                        <TextBlock Style="{StaticResource sDevicePrimaryTitle}">
                        <Run>Interval Min</Run><Run Text="&#160;"/><Run x:Name="uiConnection_ParametersChange" Text="┄"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource sDevicePrimaryData}"><Run x:Name="uiInterval_Min"/></TextBlock>
                    </StackPanel>

                    <StackPanel Style="{StaticResource sDeviceDataPanel}">
                        <TextBlock Style="{StaticResource sDevicePrimaryTitle}">
                        <Run>Interval Max</Run><Run Text="&#160;"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource sDevicePrimaryData}"><Run x:Name="uiInterval_Max"/></TextBlock>
                    </StackPanel>

                    <StackPanel Style="{StaticResource sDeviceDataPanel}">
                        <TextBlock Style="{StaticResource sDevicePrimaryTitle}">
                        <Run>Latency</Run><Run Text="&#160;"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource sDevicePrimaryData}"><Run x:Name="uiLatency"/></TextBlock>
                    </StackPanel>

                    <StackPanel Style="{StaticResource sDeviceDataPanel}">
                        <TextBlock Style="{StaticResource sDevicePrimaryTitle}">
                        <Run>Timeout</Run><Run Text="&#160;"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource sDevicePrimaryData}"><Run x:Name="uiTimeout"/></TextBlock>
                    </StackPanel>


                    <!-- This StackPanel has a name because it might be removed from the display if the
                        device doesn't have sensor.
                        (for the demo code, the sensor is a battery level, and not every device has a battery)
                    -->
                    <StackPanel Style="{StaticResource sDeviceDataPanel}" x:Name="uiDeviceDataSensor">
                        <TextBlock Style="{StaticResource sDevicePrimaryTitle}">
                        <Run>Sensor</Run><Run Text=" "/><Run x:Name="uiSensorChange" Text=" "/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource sDevicePrimaryData}"><Run x:Name="uiSensor"/></TextBlock>
                        <Line Tag="BatteryLevelColor" Style="{StaticResource sGraphLineKey}" />
                    </StackPanel>

                </GridView>
                <oxyplot:PlotView Grid.Row="2" x:Name="uiOxyPlot" Background="Transparent" Visibility="Visible"  />
                <Grid Grid.Row="2" x:Name="uiDataGridPanel" Visibility="Collapsed" >
                    <tv:TableView x:Name="uiTableView" IsReadOnly="True" />
                </Grid>

            </Grid>
            <TextBlock Grid.Row="2" Style="{StaticResource sDeviceMinorText}"><Run>Bluetooth Address: </Run><Run x:Name="uiAddress"/></TextBlock>
            <local:BTConnectionControl Grid.Row="3" x:Name="uiBTConnectionControl" />
        </Grid>
    </Border>
</UserControl>
