<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BluetoothWinUI3">

    <Style x:Key="sAllFonts" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Candara" />
    </Style>


    <Style x:Key="sDeviceBorder" TargetType="Border">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="Gray" />
        <Setter Property="Height" Value="400" />
        <Setter Property="Width" Value="400" />
    </Style>

    <Style x:Key="sDeviceTitle" TargetType="TextBlock" BasedOn="{StaticResource sAllFonts}">
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="24" />
    </Style>
    <Style x:Key="sDeviceMinorText" TargetType="TextBlock" BasedOn="{StaticResource sAllFonts}">
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="FontSize" Value="10" />
    </Style>

</ResourceDictionary>
