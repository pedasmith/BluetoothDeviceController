<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="BluetoothWinUI3.BTConnectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BluetoothWinUI3"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="30" />
            <ColumnDefinition Width="50" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" x:Name="uiConnectInfo">
            <TextBlock Width="25" x:Name="uiIcon"/>
            <Button Content="Connect" Click="OnConnect" />
        </StackPanel>
        <TextBlock Grid.Column="1" x:Name="uiStatus" Style="{StaticResource sAdvertisementData}" />
        <TextBlock Grid.Column="2" x:Name="uiBatteryLevelIcon" Style="{StaticResource sDeviceDataIcon}" />
        <TextBlock Grid.Column="3" x:Name="uiBatteryLevelPercent" Style="{StaticResource sDeviceData}" />

    </Grid>
</UserControl>
